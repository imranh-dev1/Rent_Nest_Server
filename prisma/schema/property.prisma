model Property {
    id           String               @id @default(uuid())
    title        String
    description  String
    address      String
    city         String
    rentAmount   Float
    bedrooms     Int
    bathrooms    Int
    area         Int
    amenities    String[]
    images       String[]
    availability PropertyAvailability @default(AVAILABLE)

    landlordId String
    categoryId String
    landlord   User     @relation(fields: [landlordId], references: [id])
    category   Category @relation(fields: [categoryId], references: [id])

    rentalRequests RentalRequest[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("properties")
}
