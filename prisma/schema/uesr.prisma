model User {
    id         String     @id @default(uuid())
    name       String     @db.VarChar(255)
    email      String     @unique
    password   String
    phone      String?
    role       Role
    status     UserStatus @default(ACTIVE)
    profileImg String?

    properties Property[]
    // rentals    RentalRequest[]
    // reviews    Review[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}
